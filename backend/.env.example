# Port the HTTP server listens on
PORT=3000

# Environment: development or production
NODE_ENV=development

# Secret used to sign the session cookie. Use a long random string in production.
SESSION_SECRET=change-me-to-a-long-random-string

# How long a session stays valid, in milliseconds (default: 7 days)
SESSION_MAX_AGE_MS=604800000

# Comma-separated list of origins allowed to call the API with credentials.
# Example for the GitHub Pages frontend:
# CORS_ORIGINS=https://kozmiysky-laboratory.github.io
CORS_ORIGINS=http://localhost:3000

# Absolute or relative path to the SQLite database file
DATABASE_PATH=./data/stopfish.sqlite
